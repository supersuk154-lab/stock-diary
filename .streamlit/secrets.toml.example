# ==========================================================
# 비밀키 설정 파일
# ==========================================================
# 경로:  내앱폴더/.streamlit/secrets.toml
# 🚨 이 파일은 절대 GitHub에 올리지 마세요! (.gitignore 에 .streamlit/ 추가)
# ==========================================================

# ▼ Supabase 대시보드 → ⚙️ Settings → "Data API"
SUPABASE_URL = "https://여기에프로젝트URL.supabase.co"
SUPABASE_ANON_KEY = "여기에anon키"

# ▼ https://aistudio.google.com/apikey
GEMINI_API_KEY = "여기에Gemini키"

# ==========================================================
# 🛠️ 개발 모드 (본인 PC에서 개발할 때만 true)
# ==========================================================
# true로 설정하면:
#   - 한 번 로그인하면 그 후 매번 인증코드 입력 생략
#   - 세션이 자동 갱신되어 약 30일 유지
#   - 메일 발송 제한(시간당 2~3건)에 안 걸림
#
# 🚨 친구 공유/Streamlit Cloud 배포 시엔 반드시 false 또는 줄 삭제!
DEV_MODE = true

# ==========================================================
# 비밀키 설정 파일
# ==========================================================
# 사용 방법:
#   1. 이 파일을 프로젝트 폴더의 ".streamlit" 폴더 안에 두세요.
#      (폴더가 없으면 만드세요. 폴더 이름 앞의 점(.)이 중요합니다)
#
#   최종 경로:  내앱폴더/.streamlit/secrets.toml
#
#   2. 아래 3개 값을 본인 것으로 채우세요.
#   3. 🚨 이 파일은 절대 GitHub에 업로드하지 마세요!
#      (.gitignore에 ".streamlit/secrets.toml" 추가)
# ==========================================================

# ▼ Supabase에서 가져오기:
#   대시보드 → 프로젝트 선택 → 왼쪽 아래 ⚙️ Settings → "Data API"
#   - Project URL → SUPABASE_URL 에 붙여넣기
#   - Project API keys 의 "anon public" 키 → SUPABASE_ANON_KEY 에 붙여넣기
SUPABASE_URL = "https://여기에프로젝트URL.supabase.co"
SUPABASE_ANON_KEY = "여기에anon키"

# ▼ Google AI Studio에서 가져오기:
#   https://aistudio.google.com/apikey
GEMINI_API_KEY = "여기에Gemini키"
